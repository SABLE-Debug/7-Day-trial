{
  "name": "mobius-video",
  "version": "0.1.0",
  "description": "MOBIUS video pipeline — audit Loom intro/outro cards plus landing promos. Remotion + ElevenLabs + ffmpeg.",
  "private": true,
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render src/index.ts Promo out/mobius-promo.mp4",
    "render:intro": "remotion render src/index.ts AuditLoomIntro out/audit-loom-intro.mp4",
    "render:outro": "remotion render src/index.ts AuditLoomOutro out/audit-loom-outro.mp4",
    "render:short": "remotion render src/index.ts LandingPromo out/mobius-short.mp4 --props=./scenes/mobius-promo.json",
    "tts": "node scripts/tts.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
